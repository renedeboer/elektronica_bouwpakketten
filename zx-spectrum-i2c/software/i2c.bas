10 REM=== I2C CONTROLLER CONSTANTS===

20 REM Data & control registers
30 LET S0=2*16+15:REM &2F%00101111Data register (A4=0)
40 LET S1=3*16+15:REM &3F%00111111Control / Status register (A4=1)

50 REM Own I2C address
60 LET OWNADDR=85:REM &55%01010101Shifted left by  -> &AA

70 REM Clock control values
80 LET CLCK4=16:REM &10%00010000 4.43 MHz system clock
90 LET CLCK6=20:REM &14%00010100 6.00 MHz system clock
100 LET CLCK12=28:REM &1C%00011100 12.00 MHz system clock

110 REM Timeout (0=256 tries in original code)
120 LET TIMEOUT=0:REM &00%00000000

130 REM===CONTROL BITS===
140 LET PIN=128:REM &80%10000000Pending interrupt / status
150 LET ESO=64:REM &40%01000000Enable serial output
160 LET ES1=32:REM &20%00100000Register select bit 1
170 LET ES2=16:REM &10%00010000Register select bit 2
180 LET ENI=8:REM &08%00001000Enable external interrupt
190 LET STA=4:REM &04%00000100Generate START condition
200 LET STO=2:REM &02%00000010Generate STOP condition
210 LET ACK=1:REM &01%00000001Generate ACK

220 REM===STATUS BITS===
230 LET STS=32:REM &20%00100000Stop detected (slave)
240 LET BER=16:REM &10%00010000Bus error
250 LET LRB=8:REM &08%00001000Last received bit
260 LET AAS=4:REM &04%00000100Addressed as slave
270 LET LAB=2:REM &02%00000010Lost arbitration
280 LET BB=1:REM &01%00000001Bus busy

290 REM===COMPOSITE CONTROL VALUES===
300 LET SENDI2CSTART=PIN+ESO+STA:REM &C4%11000100
301 LET SENDI2CSTARTACK=PIN+ESO+STA+ACK:REM &C5%11000101
302 LET SENDI2CSTOPACK=PIN+ESO+STO+ACK:REM &C3%11000011
310 LET SENDI2CSTOP=PIN+ESO+STO:REM &C2%11000010
320 LET CLEARI2CBUS=PIN+ESO+ACK:REM &C1%11000001
330 LET NEGATIVEACK=ESO:REM &40%01000000

340 LET S2=PIN+ES1:REM &A0%10100000
350 LET RESET=PIN:REM &80%10000000

360 REM===RETURN / ERROR CODES===
370 LET OK=0:REM &00%00000000
380 LET ERRWAITPIN=1:REM &01%00000001
390 LET ERRNOACK=2:REM &02%00000010
400 LET ERRBUSBUSY=3:REM &03%00000011

410 REM===INIT===
420 OUT S1,RESET
430 OUT S0,OWNADDR
440 OUT S1,S2
450 OUT S0,CLCK12:PAUSE 25
460 OUT S1,CLEARI2CBUS
470 PAUSE 25:REM 25/50 sec

500 LET X=255:LET ADDR=64:REM &20
510 OUT S0,ADDR:OUT S1,SENDI2CSTARTACK:PAUSE 1 
520 OUT S0,X:OUT S1,SENDI2CSTOPACK
530 LET X=255-X:PAUSE 50:GOTO 510


